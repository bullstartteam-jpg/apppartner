{
  "name": "bullstart-partner",
  "version": "1.0.0",
  "description": "BullStart Partner Desktop App — partners view the gangsheets assigned to them; talks to hubbullstart API.",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "BS_DEV=1 webpack serve --config webpack.renderer.config.js & BS_DEV=1 electron .",
    "build:renderer": "webpack --config webpack.renderer.config.js --mode production",
    "build:win": "npm run build:renderer && electron-builder --win",
    "build:mac": "npm run build:renderer && electron-builder --mac",
    "build:linux": "npm run build:renderer && electron-builder --linux"
  },
  "build": {
    "appId": "com.bullstart.partner",
    "productName": "BullStart Partner",
    "directories": {
      "output": "dist",
      "buildResources": "build-resources"
    },
    "files": [
      "src/main/**/*",
      "build/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis",
      "icon": "build-resources/icon.png",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": "dmg",
      "icon": "build-resources/icon.png"
    },
    "linux": {
      "icon": "build-resources/icon.png"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "bullstartteam-jpg",
        "repo": "apppartner",
        "releaseType": "release"
      }
    ]
  },
  "keywords": [
    "partner",
    "gangsheet",
    "bullstart"
  ],
  "author": "BullStart Team",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@babel/preset-react": "^7.28.5",
    "@tailwindcss/postcss": "^4.2.4",
    "babel-loader": "^10.1.1",
    "css-loader": "^7.1.4",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "html-webpack-plugin": "^5.6.7",
    "postcss": "^8.5.12",
    "postcss-loader": "^8.2.1",
    "style-loader": "^4.0.0",
    "tailwindcss": "^4.2.4",
    "webpack": "^5.106.2",
    "webpack-cli": "^7.0.2",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1039.0",
    "axios": "^1.15.2",
    "electron-updater": "^6.8.3",
    "pdf-lib": "^1.17.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-router-dom": "^7.14.2"
  }
}
